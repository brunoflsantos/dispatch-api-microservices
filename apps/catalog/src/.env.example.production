# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=dispatch_db_catalog
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# Application
APP_PORT=3001

# Cache
CACHE_TTL=300000

# Debug Settings (optional)
LOG_LEVEL=debug
TYPEORM_LOGGING=false

# Test Environment
TEST_ENV=false
SEED_TEST_DATA=true

# Node Environment
NODE_ENV=production # Possible values: local, production
