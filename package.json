{
  "name": "dispatch-api-microservices",
  "version": "1.0.0",
  "description": "Dispatch: E-commerce API with NestJS, PostgreSQL, Redis and RabbitMQ.",
  "author": "Bruno Fernandes",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "chmod +x scripts/build.sh && bash scripts/build.sh",
    "postbuild": "node scripts/copy-shared-i18n.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "chmod +x scripts/start-local.sh && bash scripts/start-local.sh",
    "start:prod": "chmod +x scripts/start-prod.sh && bash scripts/start-prod.sh",
    "reset": "chmod +x scripts/reset.sh && bash scripts/reset.sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:cov": "jest --ci --coverage",
    "test:unit": "jest --ci --selectProjects unit",
    "test:int": "jest --ci --passWithNoTests --selectProjects integration --runInBand",
    "test:e2e": "jest --ci --selectProjects e2e --runInBand",
    "test:load:local": "docker run --rm -i grafana/k6 run -e BASE_URL=http://host.docker.internal:3000 - <test/load-test.js",
    "test:load:docker": "docker run --rm -i --network=dispatch-api_dispatch-network grafana/k6 run -e BASE_URL=http://api-gateway:3000 - <test/load-test.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/typeorm.config.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/typeorm.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/typeorm.config.ts",
    "reset-db": "chmod +x scripts/reset-db.sh && bash scripts/reset-db.sh",
    "create-db": "chmod +x scripts/create-db.sh && bash scripts/create-db.sh",
    "nest:build:api-gateway": "bash -c 'set -a; source apps/api-gateway/.env.local; set +a; nest build api-gateway'",
    "nest:build:catalog": "bash -c 'set -a; source apps/catalog/.env.local; set +a; nest build catalog'",
    "nest:build:identity": "bash -c 'set -a; source apps/identity/.env.local; set + a; nest build identity'",
    "nest:build:notifications": "bash -c 'set -a; source apps/notifications/.env.local; set +a; nest build notifications'",
    "nest:build:orders": "bash -c 'set -a; source apps/orders/.env.local; set +a; nest build orders'",
    "nest:build:payments": "bash -c 'set -a; source apps/payments/.env.local; set +a; nest build payments'",
    "nest:build:all": "concurrently -n \"gw,catalog,identity,orders,notif,pay\" -c \"blue,green,yellow,red,magenta,cyan\" \"npm:nest:build:api-gateway\" \"npm:nest:build:catalog\" \"npm:nest:build:identity\" \"npm:nest:build:orders\" \"npm:nest:build:notifications\" \"npm:nest:build:payments\"",
    "nest:start:api-gateway": "bash -c 'set -a; source apps/api-gateway/.env.local; set +a; nest start api-gateway --debug=9229 --watch'",
    "nest:start:catalog": "bash -c 'set -a; source apps/catalog/.env.local; set +a; nest start catalog --debug=9230 --watch'",
    "nest:start:identity": "bash -c 'set -a; source apps/identity/.env.local; set +a; nest start identity --debug=9231 --watch'",
    "nest:start:notifications": "bash -c 'set -a; source apps/notifications/.env.local; set +a; nest start notifications --debug=9233 --watch'",
    "nest:start:orders": "bash -c 'set -a; source apps/orders/.env.local; set +a; nest start orders --debug=9232 --watch'",
    "nest:start:payments": "bash -c 'set -a; source apps/payments/.env.local; set +a; nest start payments --debug=9234 --watch'",
    "nest:start:all": "concurrently -n \"gw,catalog,identity,orders,notif,pay\" -c \"blue,green,yellow,red,magenta,cyan\" --kill-others-on-fail \"npm:nest:start:api-gateway\" \"npm:nest:start:catalog\" \"npm:nest:start:identity\" \"npm:nest:start:orders\" \"npm:nest:start:notifications\" \"npm:nest:start:payments\"",
    "docker:infra": "docker compose up -d postgres redis rabbitmq loki grafana promtail",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build --no-cache",
    "docker:logs": "docker compose logs -f",
    "docker:status": "docker compose ps"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/nestjs": "^6.20.6",
    "@eslint/js": "^10.0.1",
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.6",
    "argon2": "^0.44.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "cacheable": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "globals": "^17.6.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "keyv": "^5.6.0",
    "nestjs-i18n": "^10.6.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "redlock": "^5.0.0-beta.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.0.0",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "typescript-eslint": "^8.59.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@testcontainers/postgresql": "^11.13.0",
    "@testcontainers/redis": "^11.13.0",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/redlock": "^4.0.8",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "forceExit": true,
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^libs/(.*)$": "<rootDir>/../libs/$1",
      "^@/shared/(.*)$": "<rootDir>/../libs/common/$1",
      "^@/modules/(.*)$": "<rootDir>/../libs/common/modules/$1",
      "^@/config/(.*)$": "<rootDir>/../libs/common/config/$1",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "projects": [
      {
        "displayName": "unit",
        "rootDir": "<rootDir>/apps",
        "testRegex": ".*\\.spec\\.ts$",
        "testPathIgnorePatterns": [
          "<rootDir>/.*/test/"
        ],
        "transform": {
          "^.+\\.(t|j)s$": [
            "ts-jest",
            {
              "tsconfig": "<rootDir>/../tsconfig.json"
            }
          ]
        },
        "testEnvironment": "node"
      },
      {
        "displayName": "integration",
        "rootDir": "<rootDir>/apps",
        "testRegex": ".*\\.int-spec\\.ts$",
        "testPathIgnorePatterns": [
          "<rootDir>/.*/test/"
        ],
        "transform": {
          "^.+\\.(t|j)s$": [
            "ts-jest",
            {
              "tsconfig": "<rootDir>/../tsconfig.json"
            }
          ]
        },
        "testEnvironment": "node"
      },
      {
        "displayName": "e2e",
        "rootDir": "<rootDir>/apps",
        "testRegex": ".*\\.e2e-spec\\.ts$",
        "transform": {
          "^.+\\.(t|j)s$": [
            "ts-jest",
            {
              "tsconfig": "<rootDir>/../tsconfig.json"
            }
          ]
        },
        "testEnvironment": "node"
      }
    ]
  }
}
